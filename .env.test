# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# The project runs on MySQL (ddev). Symfony does NOT load .env.local in the
# test env, and the committed .env default is the unused Symfony postgres
# skeleton — so point functional tests at ddev's MySQL. Functional tests wrap
# each case in a transaction and roll back, so they don't mutate this database.
DATABASE_URL="mysql://db:db@db:3306/db?serverVersion=8.0&charset=utf8mb4"
