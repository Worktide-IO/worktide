{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}Termin verschoben{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">Ihr Termin wurde verschoben</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:16px;">
            {% if inviteeName %}Hallo {{ inviteeName }},{% else %}Hallo,{% endif %}<br><br>
            Ihr Termin wurde auf einen neuen Zeitpunkt verschoben. Hier sind die aktualisierten Details:
        </td>
    </tr>
    <tr>
        <td style="padding-bottom:20px;">
            <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%; border:1px solid #e4e4e7; border-radius:8px;">
                <tr><td style="padding:14px 16px; font-size:16px; font-weight:600;">{{ title }}</td></tr>
                <tr><td style="padding:0 16px 12px; font-size:14px; line-height:1.7; color:#3f3f46;">
                    {% if oldStart %}<span style="color:#a1a1aa; text-decoration:line-through;">{{ oldStart|date('l, d.m.Y') }}, {{ oldStart|date('H:i') }}</span><br>{% endif %}
                    📅 {{ start|date('l, d.m.Y') }}<br>
                    🕒 {{ start|date('H:i') }}–{{ end|date('H:i') }} ({{ durationMinutes }} Min., {{ timezone }})<br>
                    📍 {{ location }}
                    {% if hostName %}<br>👤 {{ hostName }}{% endif %}
                    {% if notes %}<br><br><span style="color:#71717a;">Ihre Notiz:</span> {{ notes }}{% endif %}
                </td></tr>
            </table>
        </td>
    </tr>
    <tr>
        <td style="font-size:13px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            Der aktualisierte Termin liegt als Kalender-Datei (.ics) bei — anklicken, um Ihren Kalender zu aktualisieren.
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            Passt der neue Termin nicht? <a href="{{ rescheduleUrl }}" style="color:{{ primary }};">Erneut verschieben</a>
            oder <a href="{{ cancelUrl }}" style="color:{{ primary }};">stornieren</a>.
        </td>
    </tr>
{% endblock %}
