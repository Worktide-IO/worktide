{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}{{ subject }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#a1a1aa; padding-bottom:6px;">{{ newsletterTitle }}</td>
    </tr>
    <tr>
        <td style="font-size:20px; font-weight:600; padding-bottom:18px;">{{ subject }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.7; color:#3f3f46;">
            {{ bodyHtml|raw }}
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#a1a1aa; border-top:1px solid #e4e4e7; padding-top:16px; margin-top:24px;">
            {{ 'email.newsletter.reason'|trans({'%title%': newsletterTitle}, 'messages', locale) }}
            <a href="{{ unsubscribeUrl }}" style="color:{{ primary }};">{{ 'email.newsletter.unsubscribe'|trans({}, 'messages', locale) }}</a>.
        </td>
    </tr>
{% endblock %}
