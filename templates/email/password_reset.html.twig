{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}Passwort zurücksetzen{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">Passwort zurücksetzen</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {% if firstName %}Hallo {{ firstName }},{% else %}Hallo,{% endif %}<br><br>
            für dein {{ brand.name }}-Konto wurde ein Zurücksetzen des Passworts angefordert.
            Klicke auf den Button, um ein neues Passwort zu vergeben:
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ resetUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">Neues Passwort setzen</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            Falls der Button nicht funktioniert, kopiere diesen Link in deinen Browser:<br>
            <a href="{{ resetUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ resetUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            Der Link ist bis {{ expiresAt|date('d.m.Y H:i') }} Uhr gültig und kann nur einmal verwendet werden.<br>
            Falls du das nicht angefordert hast, kannst du diese E-Mail ignorieren — dein Passwort bleibt unverändert.
        </td>
    </tr>
{% endblock %}
