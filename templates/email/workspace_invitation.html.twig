{% extends 'email/base.html.twig' %}
{% set loc = locale|default('de') %}

{% set primary = brand.primaryColor %}

{% set roleKeys = { 'admin': 'email.role.admin', 'member': 'email.role.member', 'guest': 'email.role.guest' } %}
{% set roleSuffix = roleKeys[role] is defined
    ? 'email.invitation.role_suffix'|trans({'%role%': roleKeys[role]|trans({}, 'messages', loc)}, 'messages', loc)
    : '' %}

{% block title %}{{ 'email.invitation.heading'|trans({'%workspace%': workspaceName}, 'messages', loc) }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">{{ 'email.invitation.heading'|trans({'%workspace%': workspaceName}, 'messages', loc) }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {{ 'email.invitation.greeting'|trans({}, 'messages', loc) }}<br><br>
            {{ 'email.invitation.body'|trans({'%workspace%': workspaceName, '%brand%': brand.name, '%role%': roleSuffix}, 'messages', loc)|raw }}
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ acceptUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">{{ 'email.invitation.cta'|trans({}, 'messages', loc) }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            {{ 'email.invitation.fallback_link'|trans({}, 'messages', loc) }}<br>
            <a href="{{ acceptUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ acceptUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            {{ 'email.invitation.valid_until'|trans({'%date%': expiresAt|date('d.m.Y')}, 'messages', loc) }}<br>
            {{ 'email.invitation.ignore'|trans({}, 'messages', loc) }}
        </td>
    </tr>
{% endblock %}
