{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}Einladung zu {{ workspaceName }}{% endblock %}

{% set roleLabels = { 'admin': 'Administrator', 'member': 'Mitglied', 'guest': 'Gast' } %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">Einladung zu {{ workspaceName }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            Hallo,<br><br>
            Sie wurden eingeladen, dem Workspace <strong>{{ workspaceName }}</strong> in {{ brand.name }}
            beizutreten{% if roleLabels[role] is defined %} (als {{ roleLabels[role] }}){% endif %}.
            Klicken Sie auf den Button, um die Einladung anzunehmen:
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ acceptUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">Einladung annehmen</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            Falls der Button nicht funktioniert, kopieren Sie diesen Link in Ihren Browser:<br>
            <a href="{{ acceptUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ acceptUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            Die Einladung ist bis {{ expiresAt|date('d.m.Y') }} gültig.<br>
            Falls Sie diese Einladung nicht erwartet haben, können Sie diese E-Mail ignorieren.
        </td>
    </tr>
{% endblock %}
