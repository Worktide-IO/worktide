{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}Zugang zum Kundenportal{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">Ihr Zugang zum Kundenportal</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {% if firstName %}Hallo {{ firstName }},{% else %}Hallo,{% endif %}<br><br>
            {% if welcomeText|default %}{{ welcomeText|nl2br }}<br><br>{% endif %}
            für Sie wurde ein Zugang zum Kundenportal eingerichtet. Bitte legen Sie
            über den folgenden Button ein Passwort fest, um sich anzumelden:
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ setPasswordUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">Passwort festlegen</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            Falls der Button nicht funktioniert, kopieren Sie diesen Link in Ihren Browser:<br>
            <a href="{{ setPasswordUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ setPasswordUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            Der Link ist bis {{ expiresAt|date('d.m.Y H:i') }} Uhr gültig und kann nur einmal verwendet werden.<br>
            Falls Sie diesen Zugang nicht erwartet haben, können Sie diese E-Mail ignorieren.
        </td>
    </tr>
{% endblock %}
