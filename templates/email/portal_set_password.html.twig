{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}{{ 'email.portal_set_password.title'|trans({}, 'messages', locale) }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">{{ 'email.portal_set_password.heading'|trans({}, 'messages', locale) }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {% if firstName %}{{ 'email.portal_set_password.greeting_named'|trans({'%name%': firstName}, 'messages', locale) }}{% else %}{{ 'email.portal_set_password.greeting'|trans({}, 'messages', locale) }}{% endif %}<br><br>
            {% if welcomeText|default %}{{ welcomeText|nl2br }}<br><br>{% endif %}
            {{ 'email.portal_set_password.body'|trans({}, 'messages', locale) }}
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ setPasswordUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">{{ 'email.portal_set_password.cta'|trans({}, 'messages', locale) }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            {{ 'email.portal_set_password.fallback_link'|trans({}, 'messages', locale) }}<br>
            <a href="{{ setPasswordUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ setPasswordUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            {{ 'email.portal_set_password.valid_until'|trans({'%date%': expiresAt|date('d.m.Y H:i')}, 'messages', locale) }}<br>
            {{ 'email.portal_set_password.ignore'|trans({}, 'messages', locale) }}
        </td>
    </tr>
{% endblock %}
