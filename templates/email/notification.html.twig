{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">{{ title }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {% if firstName %}{{ 'email.notification.greeting'|trans({'%name%': firstName}, 'messages', locale) }}{% else %}{{ 'email.notification.greeting_plain'|trans({}, 'messages', locale) }}{% endif %}<br><br>
            {% if body %}{{ body }}{% else %}{{ 'email.notification.body_fallback'|trans({}, 'messages', locale) }}{% endif %}
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ actionUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">{{ 'email.notification.cta'|trans({}, 'messages', locale) }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            {{ 'email.notification.fallback_link'|trans({}, 'messages', locale) }}<br>
            <a href="{{ actionUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ actionUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            {{ 'email.notification.footer'|trans({'%brand%': brand.name}, 'messages', locale) }}
        </td>
    </tr>
{% endblock %}
