{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}{{ 'email.notification_digest.title'|trans({}, 'messages', locale) }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">
            {% if count == 1 %}{{ 'email.notification_digest.heading_one'|trans({}, 'messages', locale) }}{% else %}{{ 'email.notification_digest.heading_many'|trans({'%count%': count}, 'messages', locale) }}{% endif %}
        </td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:16px;">
            {% if firstName %}{{ 'email.notification_digest.greeting'|trans({'%name%': firstName}, 'messages', locale) }}{% else %}{{ 'email.notification_digest.greeting_plain'|trans({}, 'messages', locale) }}{% endif %}<br><br>
            {{ 'email.notification_digest.intro'|trans({}, 'messages', locale) }}
        </td>
    </tr>
    {% for item in items %}
    <tr>
        <td style="padding-bottom:12px;">
            <div style="border:1px solid #e4e4e7; border-radius:8px; padding:12px 14px;">
                <a href="{{ item.url }}" style="color:#18181b; text-decoration:none; font-size:14px; font-weight:600;">{{ item.title }}</a>
                {% if item.body %}<div style="font-size:13px; line-height:1.5; color:#52525b; padding-top:4px;">{{ item.body }}</div>{% endif %}
                <div style="font-size:11px; color:#a1a1aa; padding-top:6px;">{{ item.occurredAt|date('d.m.Y H:i') }} {{ 'email.notification_digest.time_suffix'|trans({}, 'messages', locale) }}</div>
            </div>
        </td>
    </tr>
    {% endfor %}
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; border-top:1px solid #e4e4e7; padding-top:16px;">
            {{ 'email.notification_digest.footer'|trans({}, 'messages', locale) }}
        </td>
    </tr>
{% endblock %}
