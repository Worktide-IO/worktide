{% extends 'email/base.html.twig' %}
{% set loc = locale|default('de') %}

{% set primary = brand.primaryColor %}

{% set roleKeys = { 'manager': 'email.project_share.role_manager', 'contributor': 'email.project_share.role_contributor', 'viewer': 'email.project_share.role_viewer' } %}
{% set roleSuffix = roleKeys[role] is defined
    ? 'email.project_share.role_suffix'|trans({'%role%': roleKeys[role]|trans({}, 'messages', loc)}, 'messages', loc)
    : '' %}

{% block title %}{{ 'email.project_share.heading'|trans({'%project%': projectName}, 'messages', loc) }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">{{ 'email.project_share.heading'|trans({'%project%': projectName}, 'messages', loc) }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            {{ 'email.project_share.greeting'|trans({}, 'messages', loc) }}<br><br>
            {{ 'email.project_share.body'|trans({'%workspace%': sharingWorkspaceName, '%project%': projectName, '%brand%': brand.name, '%role%': roleSuffix}, 'messages', loc)|raw }}
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ acceptUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">{{ 'email.project_share.cta'|trans({}, 'messages', loc) }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            {{ 'email.project_share.fallback_link'|trans({}, 'messages', loc) }}<br>
            <a href="{{ acceptUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ acceptUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a;">
            {{ 'email.project_share.valid_until'|trans({'%date%': expiresAt|date('d.m.Y')}, 'messages', loc) }}
        </td>
    </tr>
{% endblock %}
