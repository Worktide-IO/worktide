{% extends 'email/base.html.twig' %}

{% set primary = brand.primaryColor %}

{% block title %}Projekt-Freigabe: {{ projectName }}{% endblock %}

{% set roleLabels = { 'manager': 'Manager', 'contributor': 'Mitarbeit', 'viewer': 'Nur Lesen' } %}

{% block content %}
    <tr>
        <td style="font-size:18px; font-weight:600; padding-bottom:16px;">Projekt-Freigabe: {{ projectName }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.6; padding-bottom:24px;">
            Hallo,<br><br>
            <strong>{{ sharingWorkspaceName }}</strong> möchte das Projekt <strong>{{ projectName }}</strong>
            in {{ brand.name }} mit Ihrem Workspace teilen{% if roleLabels[role] is defined %} (als {{ roleLabels[role] }}){% endif %}.
            Melden Sie sich an und klicken Sie auf den Button, um die Freigabe in Ihrem Workspace anzunehmen:
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:24px;">
            <a href="{{ acceptUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 24px; border-radius:8px;">Freigabe annehmen</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a; padding-bottom:8px;">
            Falls der Button nicht funktioniert, kopieren Sie diesen Link in Ihren Browser:<br>
            <a href="{{ acceptUrl }}" style="color:{{ primary }}; word-break:break-all;">{{ acceptUrl }}</a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#71717a;">
            Der Link ist bis {{ expiresAt|date('d.m.Y') }} gültig.
        </td>
    </tr>
{% endblock %}
