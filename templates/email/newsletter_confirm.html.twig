{% extends 'email/base.html.twig' %}
{% set loc = locale|default('de') %}

{% set primary = brand.primaryColor %}

{% block title %}{{ newsletterTitle }}{% endblock %}

{% block content %}
    <tr>
        <td style="font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#a1a1aa; padding-bottom:6px;">{{ newsletterTitle }}</td>
    </tr>
    <tr>
        <td style="font-size:20px; font-weight:600; padding-bottom:18px;">{{ 'email.newsletter.confirm_heading'|trans({}, 'messages', loc) }}</td>
    </tr>
    <tr>
        <td style="font-size:14px; line-height:1.7; color:#3f3f46; padding-bottom:20px;">
            {{ 'email.newsletter.confirm_intro'|trans({'%title%': newsletterTitle}, 'messages', loc) }}
        </td>
    </tr>
    <tr>
        <td style="padding-bottom:20px;">
            <a href="{{ confirmUrl }}" style="display:inline-block; background:{{ primary }}; color:#ffffff; text-decoration:none; font-size:14px; font-weight:600; padding:12px 22px; border-radius:6px;">
                {{ 'email.newsletter.confirm_cta'|trans({}, 'messages', loc) }}
            </a>
        </td>
    </tr>
    <tr>
        <td style="font-size:12px; line-height:1.6; color:#a1a1aa; border-top:1px solid #e4e4e7; padding-top:16px;">
            {{ 'email.newsletter.confirm_ignore'|trans({}, 'messages', loc) }}
        </td>
    </tr>
{% endblock %}
