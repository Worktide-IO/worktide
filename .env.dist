# Committed DEFAULTS template. Symfony's Dotenv loads this automatically when a
# local `.env` is absent (e.g. in CI) — see the loadEnv() `.env`→`.env.dist`
# fallback. It holds NON-SECRET defaults only; every secret value is empty and is
# supplied per-environment via `.env.local` / `.env.$APP_ENV.local` (gitignored)
# or the runtime environment. `.env` itself stays gitignored.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILE.
# https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
# From-address for system mail (password reset, …). Override per env.
MAILER_FROM=no-reply@worktide.ddev.site
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> worktide ###
API_HOST=api.worktide.ddev.site
###< worktide ###

###> worktide/branding ###
# White-label branding. All values are OPTIONAL — defaults reproduce the stock
# Worktide look, so an unconfigured instance stays branded as "Worktide".
# Everything here is served at the public GET /v1/branding endpoint (consumed by
# both SPAs at runtime — no frontend rebuild needed) and used in system emails.
BRAND_NAME=Worktide
# Legal entity shown in the email footer (empty → falls back to BRAND_NAME).
BRAND_LEGAL_NAME=
# Absolute logo URL. Empty → the backend serves the bundled/mounted logo at
# {DEFAULT_URI}/branding/logo (drop a file at var/branding/logo.svg to override).
BRAND_LOGO_URL=
# Optional dark-mode logo (frontend UI only).
BRAND_LOGO_URL_DARK=
# Brand colors (any CSS color; hex recommended). Primary = buttons/links/accents.
BRAND_PRIMARY_COLOR=#0F8C72
BRAND_ACCENT_COLOR=#E0623A
# Legal links. Empty → the link is hidden in emails and frontends.
BRAND_IMPRINT_URL=
BRAND_PRIVACY_URL=
# Optional support contact shown in the email footer (empty → MAILER_FROM).
BRAND_SUPPORT_EMAIL=
# From display-name on system mail (empty → BRAND_NAME).
MAILER_FROM_NAME=
###< worktide/branding ###

###> worktide/demo ###
# Demo mode. When enabled, both SPAs render a thin red banner across the top of
# every page marking the instance as a demo. Exposed via GET /v1/branding.
DEMO_MODE=false
# Banner label (empty → the SPA's default localized text).
DEMO_BANNER_TEXT=
###< worktide/demo ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=
###< lexik/jwt-authentication-bundle ###

###> symfony/mercure-bundle ###
# Worktide Mercure hub. Same value for both URLs because the SPA reaches the hub
# on the same host as the backend reaches it. The shared HS256 secret matches the
# hub's MERCURE_PUBLISHER_JWT_KEY. Override with real values via .env.local /
# runtime env in production deployments.
MERCURE_URL=https://worktide-mercure.wappler.systems/.well-known/mercure
MERCURE_PUBLIC_URL=https://worktide-mercure.wappler.systems/.well-known/mercure
# Secret — do not commit a real value. Provide it via .env.local (gitignored)
# for local dev, or the deployment's runtime environment in production.
MERCURE_JWT_SECRET=
###< symfony/mercure-bundle ###

###> OAuth Channel (Phase C.5) ###
# Worktide-global OAuth-App for MS 365 (Azure-AD-registered app).
# Per-channel overrides take precedence (see OAuth2AppCredentialsResolver).
# Leave empty to disable the global default — workspace admins then MUST
# paste per-channel client_id/client_secret in the Channel-Edit dialog.
OAUTH_GRAPH_CLIENT_ID=
OAUTH_GRAPH_CLIENT_SECRET=

# Same for Google Workspace / Gmail (Google Cloud Console OAuth client).
OAUTH_GMAIL_CLIENT_ID=
OAUTH_GMAIL_CLIENT_SECRET=

# LinkedIn (developer app with w_member_social — requires app review to post).
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=

###> egress ###
# Default-deny outbound gate. EMPTY = nothing leaves the system. Approve modules
# explicitly (comma-separated). A bare module approves all channels; "module:<uuid>"
# approves only that channel.
#   modules: email_outbound, social_publish, webhook_delivery, ticket_push, llm
#   e.g. EGRESS_ALLOW="llm,ticket_push:0192abcd-..."
EGRESS_ALLOW=
###< egress ###

###> anthropic ###
# LLM for AI social-post suggestions. Empty = feature disabled (endpoint returns 503).
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-opus-4-8.
ANTHROPIC_MODEL=
###< anthropic ###

###> research agent — external search ###
# API keys for the research agent's external-search adapters. Empty = that
# adapter is inert (no discovery). Outbound calls also require "external_search"
# in EGRESS_ALLOW.
TAVILY_API_KEY=
BUILTWITH_API_KEY=
###< research agent — external search ###

###> file storage ###
# Storage backend for FileStorage (uploads, offloaded email bodies/attachments).
# "local" (default) → var/uploads. "s3" → object storage (AWS/MinIO/UpCloud/R2).
# At 10GB+ mailbox scale set this to s3 (real values belong in .env.local).
FILE_STORAGE_ADAPTER=local
S3_KEY=
S3_SECRET=
S3_REGION=
S3_BUCKET=
# Custom endpoint for non-AWS S3 (MinIO/UpCloud/R2). Leave empty for AWS.
S3_ENDPOINT=
# Path-style addressing — usually true for MinIO/UpCloud, false for AWS.
S3_USE_PATH_STYLE=false
# Optional key prefix inside the bucket.
S3_PREFIX=
###< file storage ###

###> search ###
# Global full-text search backend. "mysql" (default) needs no service and reads
# the DB directly; "meilisearch" is a drop-in for scale (ranking, typo-tolerance,
# highlighting). MEILISEARCH_DSN empty = the Meilisearch provider is inert.
SEARCH_PROVIDER=mysql
MEILISEARCH_DSN=
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX_PREFIX=worktide
###< search ###

# OAuth-Callback redirect base — the API host. Providers redirect to
# {OAUTH_REDIRECT_BASE}/v1/channels/oauth/callback after consent.
OAUTH_REDIRECT_BASE=https://api.worktide.ddev.site

# Where the OAuth callback bounces the user back into the SPA.
SPA_BASE_URL=https://worktide-web.ddev.site
###< OAuth Channel ###

# Public base URL of the customer portal (separate app/domain). Used to build
# the "set your password" link mailed on portal-access grant. Override per-env
# (dev: the local portal dev server).
PORTAL_BASE_URL=https://portal.worktide.ddev.site
