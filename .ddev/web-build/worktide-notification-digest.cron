# Notification email digests: bundle unread notifications for users who opted
# into a "daily"/"weekly" email cadence (instant-email users are served inline
# by the notification pipeline, not here). Sends via the async Messenger mailer,
# behind the default-deny EmailOutbound egress gate.
# Daily at 07:00; weekly Monday 07:05.
0 7 * * * cd /var/www/html && php bin/console app:notifications:send-digest --frequency=daily >> /var/www/html/var/log/cron-notification-digest.log 2>&1
5 7 * * 1 cd /var/www/html && php bin/console app:notifications:send-digest --frequency=weekly >> /var/www/html/var/log/cron-notification-digest.log 2>&1
