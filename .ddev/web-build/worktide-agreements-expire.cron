# CRM agreement expiry: flip signed agreements past their validUntil to
# `expired` so the denormalised head status stays filterable. Read-only to the
# outside world (no egress) — pure local state maintenance.
# Once daily at 06:17 (off-peak, avoids the :00 thundering herd).
17 6 * * * cd /var/www/html && php bin/console app:crm:agreements:expire >> /var/www/html/var/log/cron-agreements-expire.log 2>&1
